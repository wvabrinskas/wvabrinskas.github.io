{"schemaVersion":{"patch":0,"minor":3,"major":0},"topicSections":[{"anchor":"Initializers","identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/init(from:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/init(inputSize:strides:padding:filterSize:initializer:biasEnabled:linkId:encodingType:)"],"generated":true,"title":"Initializers"},{"anchor":"Instance-Methods","identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/apply(gradients:learningRate:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/encode(to:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/forward(tensor:context:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/onInputSizeSet()"],"generated":true,"title":"Instance Methods"}],"sections":[],"metadata":{"modules":[{"name":"Neuron"}],"title":"DepthwiseConv2d","navigatorTitle":[{"text":"DepthwiseConv2d","kind":"identifier"}],"role":"symbol","roleHeading":"Class","symbolKind":"class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DepthwiseConv2d","kind":"identifier"}],"externalID":"s:6Neuron15DepthwiseConv2dC"},"hierarchy":{"paths":[["doc:\/\/Neuron\/documentation\/Neuron"]]},"identifier":{"url":"doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d","interfaceLanguage":"swift"},"abstract":[{"text":"A layer that performs a depthwise 2D convolution operation.","type":"text"}],"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/BaseConvolutionalLayer"],"title":"Inherits From","type":"inheritsFrom"},{"kind":"relationships","identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/ConvolutionalLayer","doc:\/\/Neuron\/documentation\/Neuron\/Layer","doc:\/\/Neuron\/Se","doc:\/\/Neuron\/SE"],"title":"Conforms To","type":"conformsTo"}],"primaryContentSections":[{"declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"DepthwiseConv2d"}],"languages":["swift"],"platforms":["macOS"]}],"kind":"declarations"},{"kind":"content","content":[{"anchor":"overview","level":2,"text":"Overview","type":"heading"},{"inlineContent":[{"text":"Depthwise convolution applies a single convolutional filter independently to each input channel","type":"text"},{"text":" ","type":"text"},{"text":"(depth slice), rather than mixing information across channels as a standard ","type":"text"},{"identifier":"doc:\/\/Neuron\/documentation\/Neuron\/Conv2d","type":"reference","isActive":true},{"text":" does.","type":"text"},{"text":" ","type":"text"},{"text":"The number of output channels always equals the number of input channels.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This is the first step in a "},{"type":"strong","inlineContent":[{"text":"depthwise separable convolution","type":"text"}]},{"type":"text","text":" (as used in MobileNet), where it"},{"type":"text","text":" "},{"type":"text","text":"is typically followed by a pointwise ("},{"type":"codeVoice","code":"Conv2d"},{"type":"text","text":" with a 1×1 kernel) convolution that combines the"},{"type":"text","text":" "},{"type":"text","text":"per-channel features."}],"type":"paragraph"},{"anchor":"How-it-differs-from-docNeurondocumentationNeuronConv2d","level":2,"text":"How it differs from ``doc:\/\/Neuron\/documentation\/Neuron\/Conv2d``","type":"heading"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Property"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Conv2d"}],"type":"paragraph"}],[{"inlineContent":[{"code":"DepthwiseConv2d","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Filters per channel"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"filterCount"},{"type":"text","text":" shared across all channels"}],"type":"paragraph"}],[{"inlineContent":[{"text":"1 dedicated filter per channel","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Output depth","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"filterCount","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"same as input depth"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Parameter count"}],"type":"paragraph"}],[{"inlineContent":[{"code":"filterCount × inputDepth × kH × kW","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"inputDepth × kH × kW","type":"codeVoice"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"anchor":"Usage","level":2,"text":"Usage","type":"heading"},{"syntax":"swift","code":["\/\/ Stand-alone depthwise conv on a 32×32 RGB image","let layer = DepthwiseConv2d(","    inputSize: TensorSize(rows: 32, columns: 32, depth: 3),","    strides: (1, 1),","    padding: .same,","    filterSize: (3, 3)",")","","\/\/ Typical depthwise-separable block","let sequential = Sequential {[","    DepthwiseConv2d(strides: (1, 1), padding: .same, filterSize: (3, 3)),","    Conv2d(filterCount: 64, filterSize: (1, 1))   \/\/ pointwise step","]}"],"type":"codeListing"},{"anchor":"Output-shape","level":2,"text":"Output shape","type":"heading"},{"inlineContent":[{"text":"Given an input of shape ","type":"text"},{"code":"(rows: H, columns: W, depth: D)","type":"codeVoice"},{"text":" and filter size ","type":"text"},{"code":"(rows: kH, columns: kW)","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".same"},{"type":"text","text":" padding"}]},{"text":": output is ","type":"text"},{"code":"(rows: H\/strideR, columns: W\/strideC, depth: D)","type":"codeVoice"}]}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":".valid","type":"codeVoice"},{"text":" padding","type":"text"}]},{"text":": output is ","type":"text"},{"code":"(rows: (H−kH)\/strideR+1, columns: (W−kW)\/strideC+1, depth: D)","type":"codeVoice"}],"type":"paragraph"}]}],"type":"unorderedList"},{"anchor":"Gradient-computation","level":2,"text":"Gradient computation","type":"heading"},{"inlineContent":[{"type":"text","text":"During backpropagation each filter gradient and input gradient is computed independently per"},{"type":"text","text":" "},{"type":"text","text":"channel using full convolution of the upstream gradient with the flipped filter kernel. This"},{"type":"text","text":" "},{"type":"text","text":"keeps the backward pass embarrassingly parallel across channels."}],"type":"paragraph"}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/neuron\/depthwiseconv2d"]}],"references":{"doc://Neuron/documentation/Neuron/ConvolutionalLayer":{"title":"ConvolutionalLayer","type":"topic","url":"\/documentation\/neuron\/convolutionallayer","role":"symbol","identifier":"doc:\/\/Neuron\/documentation\/Neuron\/ConvolutionalLayer","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"ConvolutionalLayer","kind":"identifier"}],"kind":"symbol","abstract":[{"type":"text","text":"A layer that performs a convolution operation"}],"navigatorTitle":[{"text":"ConvolutionalLayer","kind":"identifier"}]},"doc://Neuron/documentation/Neuron/DepthwiseConv2d/forward(tensor:context:)":{"kind":"symbol","fragments":[{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"forward"},{"kind":"text","text":"("},{"kind":"externalParam","text":"tensor"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"Tensor","preciseIdentifier":"s:6Neuron6TensorC"},{"kind":"text","text":", "},{"kind":"externalParam","text":"context"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"NetworkContext","preciseIdentifier":"s:6Neuron14NetworkContextV"},{"kind":"text","text":") -> "},{"preciseIdentifier":"s:6Neuron6TensorC","kind":"typeIdentifier","text":"Tensor"}],"abstract":[{"type":"text","text":"Performs the depthwise forward con