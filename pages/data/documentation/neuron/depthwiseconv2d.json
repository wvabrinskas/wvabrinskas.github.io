{"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"DepthwiseConv2d"}],"platforms":["macOS"],"languages":["swift"]}]},{"kind":"content","content":[{"type":"heading","level":2,"anchor":"overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"Depthwise convolution applies a single convolutional filter independently to each input channel","type":"text"},{"text":" ","type":"text"},{"text":"(depth slice), rather than mixing information across channels as a standard ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/Neuron\/documentation\/Neuron\/Conv2d"},{"text":" does.","type":"text"},{"text":" ","type":"text"},{"text":"The number of output channels always equals the number of input channels.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the first step in a "},{"type":"strong","inlineContent":[{"text":"depthwise separable convolution","type":"text"}]},{"type":"text","text":" (as used in MobileNet), where it"},{"type":"text","text":" "},{"type":"text","text":"is typically followed by a pointwise ("},{"code":"Conv2d","type":"codeVoice"},{"type":"text","text":" with a 1×1 kernel) convolution that combines the"},{"type":"text","text":" "},{"type":"text","text":"per-channel features."}]},{"type":"heading","level":2,"anchor":"How-it-differs-from-docNeurondocumentationNeuronConv2d","text":"How it differs from ``doc:\/\/Neuron\/documentation\/Neuron\/Conv2d``"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"text":"Property","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Conv2d"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"DepthwiseConv2d"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Filters per channel"}]}],[{"type":"paragraph","inlineContent":[{"code":"filterCount","type":"codeVoice"},{"type":"text","text":" shared across all channels"}]}],[{"type":"paragraph","inlineContent":[{"text":"1 dedicated filter per channel","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Output depth","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"filterCount"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"same as input depth"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Parameter count"}]}],[{"type":"paragraph","inlineContent":[{"code":"filterCount × inputDepth × kH × kW","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"inputDepth × kH × kW"}]}]]]},{"type":"heading","level":2,"anchor":"Usage","text":"Usage"},{"syntax":"swift","type":"codeListing","code":["\/\/ Stand-alone depthwise conv on a 32×32 RGB image","let layer = DepthwiseConv2d(","    inputSize: TensorSize(rows: 32, columns: 32, depth: 3),","    strides: (1, 1),","    padding: .same,","    filterSize: (3, 3)",")","","\/\/ Typical depthwise-separable block","let sequential = Sequential {[","    DepthwiseConv2d(strides: (1, 1), padding: .same, filterSize: (3, 3)),","    Conv2d(filterCount: 64, filterSize: (1, 1))   \/\/ pointwise step","]}"]},{"type":"heading","level":2,"anchor":"Output-shape","text":"Output shape"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Given an input of shape "},{"code":"(rows: H, columns: W, depth: D)","type":"codeVoice"},{"type":"text","text":" and filter size "},{"code":"(rows: kH, columns: kW)","type":"codeVoice"},{"type":"text","text":":"}]},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":".same","type":"codeVoice"},{"text":" padding","type":"text"}]},{"type":"text","text":": output is "},{"type":"codeVoice","code":"(rows: H\/strideR, columns: W\/strideC, depth: D)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".valid"},{"type":"text","text":" padding"}]},{"type":"text","text":": output is "},{"code":"(rows: (H−kH)\/strideR+1, columns: (W−kW)\/strideC+1, depth: D)","type":"codeVoice"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"heading","level":2,"anchor":"Gradient-computation","text":"Gradient computation"},{"type":"paragraph","inlineContent":[{"text":"During backpropagation each filter gradient and input gradient is computed independently per","type":"text"},{"text":" ","type":"text"},{"text":"channel using full convolution of the upstream gradient with the flipped filter kernel. This","type":"text"},{"text":" ","type":"text"},{"text":"keeps the backward pass embarrassingly parallel across channels.","type":"text"}]}]}],"variants":[{"paths":["\/documentation\/neuron\/depthwiseconv2d"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"identifier":{"url":"doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d","interfaceLanguage":"swift"},"topicSections":[{"generated":true,"identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/init(from:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/init(inputSize:strides:padding:filterSize:initializer:biasEnabled:encodingType:)"],"title":"Initializers","anchor":"Initializers"},{"generated":true,"identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/apply(gradients:learningRate:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/encode(to:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/forward(tensor:context:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/onInputSizeSet()"],"title":"Instance Methods","anchor":"Instance-Methods"}],"sections":[],"kind":"symbol","metadata":{"symbolKind":"class","role":"symbol","modules":[{"name":"Neuron"}],"navigatorTitle":[{"text":"DepthwiseConv2d","kind":"identifier"}],"externalID":"s:6Neuron15DepthwiseConv2dC","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text"