{"metadata":{"navigatorTitle":[{"text":"DepthwiseConv2d","kind":"identifier"}],"externalID":"s:6Neuron15DepthwiseConv2dC","symbolKind":"class","title":"DepthwiseConv2d","modules":[{"name":"Neuron"}],"role":"symbol","roleHeading":"Class","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DepthwiseConv2d","kind":"identifier"}]},"kind":"symbol","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/neuron\/depthwiseconv2d"]}],"hierarchy":{"paths":[["doc:\/\/Neuron\/documentation\/Neuron"]]},"relationshipsSections":[{"kind":"relationships","identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/BaseConvolutionalLayer"],"title":"Inherits From","type":"inheritsFrom"},{"kind":"relationships","identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/ConvolutionalLayer","doc:\/\/Neuron\/documentation\/Neuron\/Layer","doc:\/\/Neuron\/Se","doc:\/\/Neuron\/SE"],"title":"Conforms To","type":"conformsTo"}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"topicSections":[{"generated":true,"identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/init(from:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/init(inputSize:strides:padding:filterSize:initializer:biasEnabled:encodingType:)"],"title":"Initializers","anchor":"Initializers"},{"generated":true,"identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/apply(gradients:learningRate:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/encode(to:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/forward(tensor:context:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/onInputSizeSet()"],"title":"Instance Methods","anchor":"Instance-Methods"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"tokens":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"DepthwiseConv2d","kind":"identifier"}],"platforms":["macOS"]}]},{"kind":"content","content":[{"level":2,"text":"Overview","type":"heading","anchor":"overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Depthwise convolution applies a single convolutional filter independently to each input channel"},{"type":"text","text":" "},{"type":"text","text":"(depth slice), rather than mixing information across channels as a standard "},{"isActive":true,"type":"reference","identifier":"doc:\/\/Neuron\/documentation\/Neuron\/Conv2d"},{"type":"text","text":" does."},{"type":"text","text":" "},{"type":"text","text":"The number of output channels always equals the number of input channels."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the first step in a "},{"type":"strong","inlineContent":[{"type":"text","text":"depthwise separable convolution"}]},{"type":"text","text":" (as used in MobileNet), where it"},{"type":"text","text":" "},{"type":"text","text":"is typically followed by a pointwise ("},{"type":"codeVoice","code":"Conv2d"},{"type":"text","text":" with a 1×1 kernel) convolution that combines the"},{"type":"text","text":" "},{"type":"text","text":"per-channel features."}]},{"text":"How it differs from ``doc:\/\/Neuron\/documentation\/Neuron\/Conv2d``","level":2,"type":"heading","anchor":"How-it-differs-from-docNeurondocumentationNeuronConv2d"},{"header":"row","type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Property"}],"type":"paragraph"}],[{"inlineContent":[{"code":"Conv2d","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"DepthwiseConv2d","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Filters per channel"}],"type":"paragraph"}],[{"inlineContent":[{"code":"filterCount","type":"codeVoice"},{"type":"text","text":" shared across all channels"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"1 dedicated filter per channel"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Output depth"}],"type":"paragraph"}],[{"inlineContent":[{"code":"filterCount","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"same as input depth"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Parameter count"}],"type":"paragraph"}],[{"inlineContent":[{"code":"filterCount × inputDepth × kH × kW","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"inputDepth × kH × kW","type":"codeVoice"}],"type":"paragraph"}]]]},{"level":2,"type":"heading","text":"Usage","anchor":"Usage"},{"syntax":"swift","code":["\/\/ Stand-alone depthwise conv on a 32×32 RGB image","let layer = DepthwiseConv2d(","    inputSize: TensorSize(rows: 32, columns: 32, depth: 3),","    strides: (1, 1),","    padding: .same,","    filterSize: (3, 3)",")","","\/\/ Typical depthwise-separable block","let sequential = Sequential {[","    DepthwiseConv2d(strides: (1, 1), padding: .same, filterSize: (3, 3)),","    Conv2d(filterCount: 64, filterSize: (1, 1))   \/\/ pointwise step","]}"],"type":"codeListing"},{"level":2,"type":"heading","text":"Output shape","anchor":"Output-shape"},{"inlineContent":[{"type":"text","text":"Given an input of shape "},{"code":"(rows: H, columns: W, depth: D)","type":"codeVoice"},{"type":"text","text":" and filter size "},{"code":"(rows: kH, columns: kW)","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".same"},{"type":"text","text":" padding"}]},{"type":"text","text":": output is "},{"code":"(rows: H\/strideR, columns: W\/strideC, depth: D)","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":".valid"},{"type":"text","text":" padding"}]},{"type":"text","text":": output is "},{"code":"(rows: (H−kH)\/strideR+1, columns: (W−kW)\/strideC+1, depth: D)","type":"codeVoice"}]}]}],"type":"unorderedList"},{"level":2,"type":"heading","text":"Gradient computation","anchor":"Gradient-computation"},{"inlineContent":[{"type":"text","text":"During backpropagation each filter gradient and input gradient is computed independently per"},{"type":"text","text":" "},{"type":"text","text":"channel using full convolution of the upstream gradient with the flipped filter kernel. This"},{"type":"text","text":" "},{"type":"text","text":"keeps the backward pass embarrassingly parallel across channels."}],"type":"paragraph"}]}],"abstract":[{"text":"A layer that performs a depthwise 2D convolution operation.","type":"text"}],"references":{"doc://Neuron/documentation/Neuron":{"kind":"symbol","title":"Neuron","url":"\/documentation\/neuron","type":"topic","role":"collection","identifier":"doc:\/\/Neuron\/documentation\/Neuron","abstract":[]},"doc://Neuron/documentation/Neuron/DepthwiseConv2d/encode(to:)":{"identifier":"doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/encode(to:)","kind":"symbol","title":"encode(to:)","url":"\/documentation\/neuron\/depthwiseconv2d\/encode(to:)","type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"kind":"text","text":" "},{"text":"encode","kind":"identifier"},{"text":"(","kind":"text"},{"text":"to","kind":"externalParam"},{"text":": any ","kind":"text"},{"text":"Encoder","preciseIdentifier":"s:s7EncoderP","kind":"typeIdentifier"},{"kind":"text","text":") "},{"kind":"keyword","text":"throws"}],"abstract":[{"text":"Encodes the layer’s configuration and parameters into the given encoder.","type":"text"}]},"doc://Neuron/documentation/Neuron/ConvolutionalLayer":{"navigatorTitle":[{"kind":"identifier","text":"ConvolutionalLayer"}],"abstract":[{"type":"text","text":"A layer that performs a convolution operation"}],"role":"symbol","url":"\/documentation\/neuron\/convolutionallayer","kind":"symbol","fragments":[{"kind":"keyword","text":"protocol"},{"kind":"text","text":