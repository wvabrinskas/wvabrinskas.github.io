{"abstract":[{"text":"A layer that performs a depthwise 2D convolution operation.","type":"text"}],"relationshipsSections":[{"kind":"relationships","title":"Inherits From","identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/BaseConvolutionalLayer"],"type":"inheritsFrom"},{"kind":"relationships","title":"Conforms To","identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/ConvolutionalLayer","doc:\/\/Neuron\/documentation\/Neuron\/Layer","doc:\/\/Neuron\/Se","doc:\/\/Neuron\/SE"],"type":"conformsTo"}],"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"DepthwiseConv2d"}]}]},{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"overview","type":"heading"},{"inlineContent":[{"type":"text","text":"Depthwise convolution applies a single convolutional filter independently to each input channel"},{"type":"text","text":" "},{"type":"text","text":"(depth slice), rather than mixing information across channels as a standard "},{"type":"reference","isActive":true,"identifier":"doc:\/\/Neuron\/documentation\/Neuron\/Conv2d"},{"type":"text","text":" does."},{"type":"text","text":" "},{"type":"text","text":"The number of output channels always equals the number of input channels."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This is the first step in a "},{"type":"strong","inlineContent":[{"text":"depthwise separable convolution","type":"text"}]},{"type":"text","text":" (as used in MobileNet), where it"},{"type":"text","text":" "},{"type":"text","text":"is typically followed by a pointwise ("},{"type":"codeVoice","code":"Conv2d"},{"type":"text","text":" with a 1×1 kernel) convolution that combines the"},{"type":"text","text":" "},{"type":"text","text":"per-channel features."}],"type":"paragraph"},{"level":2,"text":"How it differs from ``doc:\/\/Neuron\/documentation\/Neuron\/Conv2d``","anchor":"How-it-differs-from-docNeurondocumentationNeuronConv2d","type":"heading"},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Property"}]}],[{"type":"paragraph","inlineContent":[{"code":"Conv2d","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"DepthwiseConv2d","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Filters per channel","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"filterCount","type":"codeVoice"},{"text":" shared across all channels","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"1 dedicated filter per channel"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Output depth","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"filterCount","type":"codeVoice"}]}],[{"inlineContent":[{"type":"text","text":"same as input depth"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Parameter count"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"filterCount × inputDepth × kH × kW"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"inputDepth × kH × kW"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"level":2,"text":"Usage","anchor":"Usage","type":"heading"},{"code":["\/\/ Stand-alone depthwise conv on a 32×32 RGB image","let layer = DepthwiseConv2d(","    inputSize: TensorSize(rows: 32, columns: 32, depth: 3),","    strides: (1, 1),","    padding: .same,","    filterSize: (3, 3)",")","","\/\/ Typical depthwise-separable block","let sequential = Sequential {[","    DepthwiseConv2d(strides: (1, 1), padding: .same, filterSize: (3, 3)),","    Conv2d(filterCount: 64, filterSize: (1, 1))   \/\/ pointwise step","]}"],"syntax":"swift","type":"codeListing"},{"level":2,"text":"Output shape","anchor":"Output-shape","type":"heading"},{"inlineContent":[{"text":"Given an input of shape ","type":"text"},{"type":"codeVoice","code":"(rows: H, columns: W, depth: D)"},{"text":" and filter size ","type":"text"},{"type":"codeVoice","code":"(rows: kH, columns: kW)"},{"text":":","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":".same","type":"codeVoice"},{"text":" padding","type":"text"}]},{"type":"text","text":": output is "},{"type":"codeVoice","code":"(rows: H\/strideR, columns: W\/strideC, depth: D)"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":".valid","type":"codeVoice"},{"text":" padding","type":"text"}]},{"type":"text","text":": output is "},{"code":"(rows: (H−kH)\/strideR+1, columns: (W−kW)\/strideC+1, depth: D)","type":"codeVoice"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"text":"Gradient computation","anchor":"Gradient-computation","type":"heading"},{"inlineContent":[{"text":"During backpropagation each filter gradient and input gradient is computed independently per","type":"text"},{"text":" ","type":"text"},{"text":"channel using full convolution of the upstream gradient with the flipped filter kernel. This","type":"text"},{"text":" ","type":"text"},{"text":"keeps the backward pass embarrassingly parallel across channels.","type":"text"}],"type":"paragraph"}]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/neuron\/depthwiseconv2d"]}],"topicSections":[{"generated":true,"anchor":"Initializers","title":"Initializers","identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/init(from:)","doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/init(inputSize:strides:padding:filterSize:initializer:biasEnabled:linkId:encodingType:)"]},{"generated":true,"anchor":"Instance-Methods","title":"Instance Methods","identifiers":["doc:\/\/Neuron\/documentation\/Neuron\/DepthwiseConv2d\/apply(gradients:learn