","                         │","                         ▼","           ┌─────────────────────────────┐","           │   updateLock.with { ... }   │ ◄─── NSLock protection","           │   - Update means[@Atomic]   │","           │   - Update m2s[@Atomic]     │","           │   - Welford variance calc   │","           └─────────────────────────────┘","                         │","                         ▼","           ┌─────────────────────────────┐","           │  if iterations == batchSize │","           │    condition.broadcast()    │ ◄─── Signal all waiting","           │  else                       │","           │    condition.wait()         │ ◄─── Wait for completion","           └─────────────────────────────┘","                         │","                         ▼","           ┌─────────────────────────────┐","           │   condition.unlock()        │","           │   All threads synchronized  │","           └─────────────────────────────┘","                         │","                         ▼","           ┌─────────────────────────────┐","           │  Individual normalize3D()   │","           │  - Use cached statistics    │","           │  - Apply gamma\/beta scaling │","           │  - Store in ThreadStorage   │ ◄─── Thread-local cache","           └─────────────────────────────┘"]},{"inlineContent":[{"inlineContent":[{"text":"Key Synchronization Points:","type":"text"}],"type":"strong"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"NSCondition"},{"text":" (","type":"text"},{"type":"codeVoice","code":"condition"},{"text":"): Ensures all threads wait until the entire batch has computed statistics","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"NSLock"},{"type":"text","text":" ("},{"type":"codeVoice","code":"updateLock"},{"type":"text","text":"): Protects shared state updates during Welford variance calculation"}],"type":"paragraph"}]},